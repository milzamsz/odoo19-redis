<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         cb.async.channel — List View
         ============================================================ -->

    <record id="view_cb_async_channel_list" model="ir.ui.view">
        <field name="name">cb.async.channel.list</field>
        <field name="model">cb.async.channel</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="stream_key"/>
                <field name="priority"/>
                <field name="consumer_group"/>
                <field name="task_count" string="Tasks"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         cb.async.channel — Form View
         ============================================================ -->

    <record id="view_cb_async_channel_form" model="ir.ui.view">
        <field name="name">cb.async.channel.form</field>
        <field name="model">cb.async.channel</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Channel Name"/></h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="code"/>
                            <field name="stream_key"/>
                            <field name="priority"/>
                            <field name="consumer_group"/>
                        </group>
                        <group string="Options">
                            <field name="max_workers"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         cb.async.channel — Action
         ============================================================ -->

    <record id="action_cb_async_channel" model="ir.actions.act_window">
        <field name="name">Channels</field>
        <field name="res_model">cb.async.channel</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first async channel
            </p>
            <p>
                Channels map to Redis Streams. Each channel has a priority level
                and a consumer group that workers use to cooperatively process tasks.
            </p>
        </field>
    </record>

</odoo>
